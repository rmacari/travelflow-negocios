{
  "manifest_version": 3,
  "name": "Zap Negócios",
  "version": "1.55",
  "description": "Mini CRM universal para WhatsApp Web: gerencie leads, negócios, tarefas e lembretes com banco próprio em qualquer empresa.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://travelflow.tur.br/*",
    "https://*/*"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Zap Negócios",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://travelflow.tur.br/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://travelflow.tur.br/*"
      ],
      "js": [
        "page-bridge.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
