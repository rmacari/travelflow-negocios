# =============================================================================
# Zap Negócios — db.conf.example
# =============================================================================
# Arquivo de configuração do backend PHP.
#
# INSTRUÇÕES:
#   1. Copie este arquivo para db.conf (mesmo diretório)
#   2. Preencha os valores reais abaixo
#   3. NUNCA envie db.conf para repositórios públicos (git, etc.)
#   4. Configure o servidor para bloquear acesso direto a arquivos .conf
#
# Autor:   Ricardo Macari
# Contato: macari@gmail.com
# Projeto: Zap Negócios
# =============================================================================

# Credenciais do banco de dados MySQL
DB_HOST=localhost
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASS=sua_senha

# Origens permitidas para requisições CORS (CRM e WhatsApp Web)
ALLOWED_ORIGIN=https://travelflow.tur.br,https://web.whatsapp.com

# Chave de API — usada por todos os usuários para operações normais
# (salvar, buscar e excluir negócios)
# Gere com: openssl rand -hex 32
API_KEY=substitua_por_uma_chave_secreta_longa_e_aleatoria

# Chave de administrador — necessária para gerenciar campos (add_field,
# remove_field, get_fields). Deve ser diferente da API_KEY.
# Somente informe esta chave nas Opções da extensão de usuários administradores.
# Gere com: openssl rand -hex 32
ADMIN_KEY=substitua_por_outra_chave_secreta_longa_e_aleatoria
